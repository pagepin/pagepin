# pagepin configuration — copy to .env and edit:
#   cp .env.example .env
# Use with `docker run --env-file .env`, docker-compose `env_file:`, or a process manager.
# Every line below shows the built-in default; uncomment only what you need to change.
# Workers (Cloudflare) read the same names from wrangler vars/secrets, except the DB
# (D1 binding) and storage (R2 binding), which are configured in wrangler.jsonc.

# --- Core -------------------------------------------------------------------
PAGEPIN_PORT=8000                          # HTTP listen port
PAGEPIN_DATA_DIR=./data                    # data root: SQLite DB, generated secret, fs storage
# PAGEPIN_BASE_URL=http://localhost:8000   # public URL of the instance (single-domain mode)
# PAGEPIN_SECRET=                          # session signing key (use ≥32 random chars if you set it); unset → generated at {DATA_DIR}/secret
# PAGEPIN_SESSION_TTL_H=8                  # session lifetime (hours)
# PAGEPIN_DEVICE_TOKEN_TTL_DAYS=90         # browser device-login token lifetime (days); 0 = never expires
# PAGEPIN_DEFAULT_LOCALE=en                # fallback UI/API language: en | zh. Per request, ?lang= → pp_lang cookie → Accept-Language override it.

# --- Dual-domain mode (optional) --------------------------------------------
# Set BOTH to split the console/API and hosted content onto separate origins.
# PAGEPIN_CONSOLE_HOST=pagepin.example.com
# PAGEPIN_CONTENT_HOST=pages.example.com
# PAGEPIN_EXTERNAL_SCHEME=https            # scheme used to build external URLs in dual-domain mode

# --- Database ---------------------------------------------------------------
# Default: local SQLite file file:{PAGEPIN_DATA_DIR}/pagepin.db (zero-config).
# The driver is inferred from PAGEPIN_DB_URL's scheme (self-hosted Node only;
# Workers always use D1 and ignore these):
#   libsql:// , file:           -> SQLite / libSQL (e.g. Turso, with an auth token)
#   postgres:// , postgresql:// -> PostgreSQL
#   mysql://                    -> MySQL 8.0+
# Pick ONE:
# PAGEPIN_DB_URL=libsql://your-db.turso.io
# PAGEPIN_DB_URL=postgres://user:pass@host:5432/pagepin
# PAGEPIN_DB_URL=mysql://user:pass@host:3306/pagepin
# PAGEPIN_DB_AUTH_TOKEN=                   # libSQL/Turso token only; blank for local file / pg / mysql (creds in URL)
# PAGEPIN_DB_DRIVER=                       # sqlite|postgres|mysql; only to override the URL-scheme inference

# --- Auth: mode & registration ----------------------------------------------
PAGEPIN_AUTH_MODE=password                 # password | oidc | none (none = dev auto-login as admin)
# PAGEPIN_REGISTRATION_MODE=               # open | invite | closed (when set, locks the console UI)
# PAGEPIN_ALLOW_SIGNUP=true                # fallback signup default (password mode) when nothing else is set

# --- Auth: admin bootstrap --------------------------------------------------
# Set both to upsert an admin at startup; otherwise the first signup becomes admin.
# Leave these commented unless you want a bootstrapped admin — and never ship the
# placeholder password. On Node the password is re-asserted on every restart.
# PAGEPIN_ADMIN_EMAIL=admin@example.com
# PAGEPIN_ADMIN_PASSWORD=use-a-long-random-password

# --- Auth: OIDC (when PAGEPIN_AUTH_MODE=oidc) -------------------------------
# PAGEPIN_OIDC_ISSUER=                     # discovery via {issuer}/.well-known/openid-configuration
# PAGEPIN_OIDC_CLIENT_ID=
# PAGEPIN_OIDC_CLIENT_SECRET=
# PAGEPIN_OIDC_SCOPES=openid profile email
# PAGEPIN_OIDC_AUTH_PARAMS=                # extra authorize-URL query params, as a JSON object

# --- Auth: social login (coexists with password/oidc) -----------------------
# Comma list of providers, then id + secret per provider (must be set in pairs).
# PAGEPIN_OAUTH_PROVIDERS=google,github
# PAGEPIN_OAUTH_GOOGLE_CLIENT_ID=
# PAGEPIN_OAUTH_GOOGLE_CLIENT_SECRET=
# PAGEPIN_OAUTH_GITHUB_CLIENT_ID=
# PAGEPIN_OAUTH_GITHUB_CLIENT_SECRET=

# --- Auth: Cloudflare Turnstile (optional bot check; set both or neither) ----
# PAGEPIN_TURNSTILE_SITE_KEY=              # public, rendered in the browser
# PAGEPIN_TURNSTILE_SECRET_KEY=            # server-side siteverify, never sent to the browser

# --- Email (optional; unset → no verification mail, emails stay unverified) --
# PAGEPIN_MAIL_PROVIDER=resend             # resend | log
# PAGEPIN_MAIL_FROM=notifications@example.com   # from address; required when mail is enabled
# PAGEPIN_RESEND_API_KEY=                  # required when PAGEPIN_MAIL_PROVIDER=resend

# --- Storage ----------------------------------------------------------------
PAGEPIN_STORAGE=fs                         # fs (local disk) | s3 (S3-compatible)
# S3 mode — all four required:
# PAGEPIN_S3_ENDPOINT=                     # scheme optional, defaults to https://
# PAGEPIN_S3_BUCKET=
# PAGEPIN_S3_ACCESS_KEY=
# PAGEPIN_S3_SECRET_KEY=
# PAGEPIN_S3_PREFIX=pagepin/               # key prefix inside the bucket
# PAGEPIN_S3_REGION=auto                   # SigV4 region
# PAGEPIN_S3_FORCE_PATH_STYLE=true         # MinIO needs true

# --- Limits & quotas (defaults lean toward a public free tier) --------------
# PAGEPIN_MAX_FILE_MB=25                   # max size per uploaded file
# PAGEPIN_MAX_SITE_MB=200                  # max total size per site version (policy cap; batches above ~90MB)
# PAGEPIN_MAX_FILES=2000                   # max files per site version
# PAGEPIN_FREE_USER_MB=1024                # per-user total storage quota (MB); 0 = unlimited; admins exempt
# PAGEPIN_KEEP_VERSIONS=3                  # versions kept per site; 0 = keep all
# PAGEPIN_DEPLOY_TTL_H=2                   # unfinished batched-upload draft lifetime (hours)
# PAGEPIN_PUBLIC_MAX_HOURS=168             # upper bound for the public-sharing window (hours)
